{
  "name": "miniwiki",
  "version": "1.0.0",
  "description": "Lightweight and customizable Next.js + MDX wiki template",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "predev": "node scripts/generate-seo-files.js",
    "prestart": "node scripts/generate-seo-files.js",
    "prebuild": "node scripts/generate-seo-files.js",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "deps:update:check": "npx npm-check-updates",
    "deps:update:safe": "npx npm-check-updates --doctor -u --doctorInstall \"yarn install\" --doctorTest \"yarn build\""
  },
  "keywords": [
    "wiki",
    "nextjs",
    "mdx",
    "tailwind"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "flexsearch": "^0.8.212",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.25",
    "lucide-react": "^1.6.0",
    "next": "^16.2.1",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.16",
    "@types/react": "^19.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.15",
    "prism-react-renderer": "^2.4.1",
    "tailwindcss": "^4.2.2"
  }
}
