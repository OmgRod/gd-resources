{
  "name": "miniwiki",
  "version": "1.0.0",
  "description": "Lightweight and customizable Next.js + MDX wiki template",
  "private": true,
  "scripts": {
    "predev": "node scripts/generate-seo-files.js",
    "prestart": "node scripts/generate-seo-files.js",
    "prebuild": "node scripts/generate-seo-files.js",
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "deps:update:check": "npx npm-check-updates",
    "deps:update:safe": "npx npm-check-updates --doctor -u --doctorInstall \"yarn install\" --doctorTest \"yarn build\""
  },
  "keywords": [
    "wiki",
    "nextjs",
    "mdx",
    "tailwind"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@icons-pack/react-simple-icons": "^13.13.0",
    "flexsearch": "^0.8.212",
    "gray-matter": "^4.0.3",
    "katex": "^0.17.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.7",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "twemoji": "^14.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/react": "^19.2.15",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "prism-react-renderer": "^2.4.1",
    "tailwindcss": "^4.3.0"
  }
}
